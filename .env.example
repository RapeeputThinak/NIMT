# Rename this file to .env and fill in your email SMTP credentials.
# Do not commit .env to version control.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@nimt.local
MAIL_FROM_NAME="NIMT Training Service"
